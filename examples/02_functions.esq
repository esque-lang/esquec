# Example 02: Functions with parameters
# Demonstrates: multi-arg functions, function calls, recursion-like composition

fn add(a: i32, b: i32) -> i32 = a + b

fn multiply(x: i32, y: i32) -> i32 = x * y

fn square(n: i32) -> i32 = multiply(n, n)

fn sum_of_squares(a: i32, b: i32) -> i32 = {
    let sq_a = square(a);
    let sq_b = square(b);
    add(sq_a, sq_b)
}

# Main: compute 3² + 4² = 9 + 16 = 25 (Pythagorean triple!)
fn main() -> i32 = sum_of_squares(3, 4)
