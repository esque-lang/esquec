fn main() -> i32 = {
    let a = [[1.0, 2.0], [3.0, 4.0]];  // 2x2
    let b = [[5.0, 6.0], [7.0, 8.0]];  // 2x2
    let c = a @ b;
    // c[0,0] = 1*5 + 2*7 = 19
    // c[0,1] = 1*6 + 2*8 = 22
    // c[1,0] = 3*5 + 4*7 = 43
    // c[1,1] = 3*6 + 4*8 = 50
    // Sum: 19 + 22 + 43 + 50 = 134
    (+/ (+/ c)) as i32  // reduce rows, then reduce result
}
